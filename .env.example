# =====================================================
# NUTRIA ENVIRONMENT CONFIGURATION
# =====================================================
# 
# This file is a TEMPLATE for environment setup.
# 
# STEPS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real credentials
# 3. Keep .env PRIVATE (never commit to Git)
#
# =====================================================

# TELEGRAM BOT
# Get your token from: https://t.me/BotFather
TELEGRAM_TOKEN=your_telegram_token_here

# GROQ API (AI Service)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# FIREBASE DATABASE
# URL to your Firebase Realtime Database
FIREBASE_DATABASE_URL=https://your-project-rtdb.firebaseio.com/

# FIREBASE CREDENTIALS
# Path to serviceAccountKey.json file downloaded from Firebase
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
